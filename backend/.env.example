# Copy this to .env and fill in real values. Never commit .env.
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

PORT=5000
JWT_SECRET=your-64-char-random-secret-here

ADMIN_EMAIL=admin@yourhospital.com
ADMIN_PASSWORD=your-strong-admin-password
DEMO_STAFF_EMAIL=staff@yourhospital.com
DEMO_STAFF_PASSWORD=your-strong-staff-password
STAFF_PASSWORD=your-strong-staff-password

# Comma-separated allowed frontend origins
FRONTEND_URL=https://your-app.vercel.app

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres
